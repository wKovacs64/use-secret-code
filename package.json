{
  "name": "use-secret-code",
  "version": "1.0.82",
  "private": false,
  "description": "Custom hook for adding cheat codes to your React app",
  "keywords": [
    "cheat",
    "code",
    "hook",
    "hooks",
    "react",
    "secret"
  ],
  "bugs": {
    "url": "https://github.com/wKovacs64/use-secret-code/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Justin Hall",
    "email": "justin.r.hall@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wKovacs64/use-secret-code.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    "require": "./dist/index.cjs",
    "import": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup ./src/index.ts --format cjs,esm --dts --sourcemap --clean",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm install",
    "changeset:publish": "changeset publish",
    "example:install": "pnpm --filter=example install",
    "example:build": "pnpm --filter=example run build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "prepare": "pnpm run --silent build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xstate/react": "6.1.0",
    "xstate": "5.30.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.2",
    "@wkovacs64/eslint-config": "7.14.0",
    "eslint": "9.39.4",
    "happy-dom": "20.8.9",
    "oxfmt": "0.44.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.1.2"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "packageManager": "pnpm@10.33.0"
}
